# Firebase web app config. These values are NOT secret — they ship in the
# client bundle. Access is controlled by Firestore Security Rules + Auth,
# not by hiding these. Copy this file to `.env` and fill in your project's
# values from: Firebase console → Project settings → Your apps → SDK setup.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — enables Google Analytics if set
VITE_FIREBASE_MEASUREMENT_ID=
